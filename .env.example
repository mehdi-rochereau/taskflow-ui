# ============================================================
# TaskFlow UI — Environment configuration
# ============================================================
# This file documents the environment variables used by this project.
# Angular environment files are located in src/environments/.
# Update src/environments/environment.ts before building for production.
# ============================================================

# API base URL (without /api suffix)
# Used to construct the OpenAPI spec URL for Redoc
API_BASE_URL=https://api.taskflow.mehdi-rochereau.dev

# API URL (with /api suffix)
# Used by all Angular services for HTTP requests
API_URL=https://api.taskflow.mehdi-rochereau.dev/api

# Swagger UI URL
SWAGGER_URL=https://api.taskflow.mehdi-rochereau.dev/swagger-ui/index.html
